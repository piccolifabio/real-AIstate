# Le stesse env devono essere configurate nel progetto Vercel
# (Settings → Environment Variables) per production e preview.

# ────────────────────────────────────────────────────────────
# Frontend (Vite — esposte al browser, prefisso VITE_)
# ────────────────────────────────────────────────────────────

# URL del progetto Supabase (pubblico per design)
VITE_SUPABASE_URL=https://strigywjvkhbubyszuxp.supabase.co

# Anon key di Supabase (pubblica per design — protetta da RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN0cmlneXdqdmtoYnVieXN6dXhwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU5MzM0OTcsImV4cCI6MjA5MTUwOTQ5N30.aoe0BIuDrJyYU15hWVBaxO1I8PxweWpy6assvprRkns

# Google Maps Embed API key (restretta a referrer + sola Maps Embed API)
VITE_GOOGLE_MAPS_KEY=

# Comma-separated lista email admin per UI privilegiate (es. anteprima
# privata di immobili non-published in /immobili/:id). Esposta al client
# (VITE_*) — non sensibile: è un flag UI, le mutating operations admin
# usano ADMIN_SECRET server-side via x-admin-key header.
VITE_ADMIN_EMAILS=fabiopiccoli@hotmail.it

# (Opzionale, dopo setup Sentry — vedi FIXES_TODO.md punto 9)
# VITE_SENTRY_DSN=

# ────────────────────────────────────────────────────────────
# Backend (Vercel functions — server-side, MAI esporre al client)
# ────────────────────────────────────────────────────────────

# Stesso URL di sopra (le funzioni server lo leggono senza prefisso VITE_)
SUPABASE_URL=https://strigywjvkhbubyszuxp.supabase.co

# Service role key — bypassa RLS, da non committare MAI
SUPABASE_SECRET_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Brevo
BREVO_API_KEY=

# Yousign (sandbox per ora)
